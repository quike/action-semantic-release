{
  "name": "action-semantic-release",
  "description": "Semantic Release GitHub Action",
  "version": "0.0.0",
  "type": "module",
  "author": "quike.mora <616137+quike@users.noreply.github.com>",
  "bugs": {
    "url": "https://www.github.com/quike/action-semantic-release/issues"
  },
  "contributors": [
    "quike.mora <616137+quike@users.noreply.github.com>"
  ],
  "dependencies": {
    "@actions/core": "^3.0.1",
    "@semantic-release/commit-analyzer": "^13.0.1",
    "@semantic-release/exec": "^7.0.0",
    "@semantic-release/git": "^10.0.1",
    "@semantic-release/gitlab": "^13.2.4",
    "@semantic-release/npm": "^13.0.0",
    "@semantic-release/release-notes-generator": "^14.0.3",
    "conventional-changelog-conventionalcommits": "^10.0.0",
    "conventional-changelog-ember": "^5.0.0",
    "conventional-changelog-eslint": "^6.0.0",
    "execa": "^9.5.2",
    "handlebars": "^4.7.8",
    "save-dev": "^0.0.1-security",
    "semantic-release": "^25.0.0",
    "semantic-release-slack-bot": "^4.0.2"
  },
  "devDependencies": {
    "@eslint/compat": "2.1.0",
    "@eslint/config-array": "0.23.5",
    "@eslint/js": "10.0.1",
    "@eslint/object-schema": "3.0.5",
    "@github/local-action": "7.0.1",
    "@rollup/plugin-commonjs": "29.0.3",
    "@rollup/plugin-json": "6.1.0",
    "@rollup/plugin-node-resolve": "16.0.3",
    "@vercel/ncc": "0.44.1",
    "@vitest/coverage-v8": "4.1.9",
    "cosmiconfig": "9.0.2",
    "eslint": "10.6.0",
    "eslint-config-prettier": "10.1.8",
    "eslint-plugin-prettier": "5.5.6",
    "globals": "17.7.0",
    "make-coverage-badge": "1.2.0",
    "prettier": "3.9.4",
    "prettier-eslint": "17.1.1",
    "rollup": "4.62.2",
    "rollup-plugin-analyzer": "4.0.0",
    "vitest": "4.1.9"
  },
  "engines": {
    "node": ">=20.18"
  },
  "files": [
    "./src/index.js"
  ],
  "exports": "./src/index.js",
  "main": "./src/index.js",
  "keywords": [
    "conventional-commits",
    "release",
    "semantic-release",
    "version"
  ],
  "license": "MIT",
  "scripts": {
    "bundle": "npm run format:write && npm run package",
    "lint:prettier": "prettier --check \"*.{js,json,md}\" \".github/**/*.{md,yml}\" \"docs/**/*.md\" \"{bin,lib,src,test}/**/*.js\"",
    "lint:prettier:fix": "prettier --write \"*.{js,json,md}\" \".github/**/*.{md,yml}\" \"docs/**/*.md\" \"{bin,lib,src,test}/**/*.js\"",
    "lint": "eslint src",
    "lint-fix": "eslint src --fix",
    "test": "vitest",
    "coverage": "vitest run --coverage",
    "format:write": "npx prettier --write .",
    "format:check": "npx prettier --check .",
    "local-action": "npx @github/local-action . src/main.js .env",
    "package": "npx rollup --config rollup.config.js",
    "package:watch": "npm run package -- --watch",
    "package-ncc": "ncc build src/index.js --license LICENSE"
  }
}
